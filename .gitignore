# 의존성
node_modules/

# 환경 변수 (API 키 포함 — 절대 커밋 금지)
.env
.env.local
.env.*.local

# 수집된 데이터: 원본 reviews.json 은 비공개, 요약 summary.json 만 공개 (대시보드 표시용)
data/*
!data/summary.json
!data/summary-google.json
!data/summary-app.json
!data/rank.json
# 자동 답글 캐시: 생성된 답글을 빌드 간 보존하려고 커밋 (원본 reviews 는 여전히 비공개)
!data/reply-cache.json
!data/reply-cache-google.json
!data/reply-cache-app.json

# 시스템/에디터
.DS_Store
*.log
.vscode/
.idea/

# 테스트/임시 산출물
.playwright-mcp/
*.png
!dashboard/logo.png
.claude/
